# Server
DEKO_PORT=8000
DEKO_ENV=dev
DEKO_ADMIN_PASSWORD=changeme

# Database
DEKO_DATABASE_URL=sqlite://data/deko.db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Security
DEKO_API_KEY_SECRET=generate-a-secure-random-string-here

# CORS (comma-separated origins)
DEKO_ALLOWED_ORIGINS=http://localhost:8000

# Rate Limiting
DEKO_RATE_LIMIT_PER_MINUTE=60

# Request Limits
DEKO_MAX_SCREENSHOT_SIZE_MB=10
DEKO_MAX_REQUEST_BODY_KB=512

# OpenAI Timeout (seconds)
OPENAI_TIMEOUT_SECS=30

# Webhook (optional)
DEKO_WEBHOOK_URL=
